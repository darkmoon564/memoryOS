# Copy to .env. Do not commit real credentials.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=memoryos
POSTGRES_USER=memoryos
POSTGRES_PASSWORD=change-this-local-password

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-local-password

# Production must use durable PostgreSQL and Neo4j. Set this only for tests
# that intentionally exercise the in-memory adapters.
MEMORYOS_ALLOW_IN_MEMORY_FALLBACK=false
# Docker Compose starts in lightweight deterministic integration mode by
# default.  Set these two values to true/false respectively for the full
# semantic runtime (which downloads substantially larger local ML assets).
MEMORYOS_INSTALL_ML=false
MEMORYOS_OFFLINE_MODE=true
# Deterministic hash embeddings and token-overlap reranking are for tests only.
# Non-container production deployments fail closed if semantic models are unavailable.
OFFLINE_MODE=false
MEMORYOS_ALLOW_MOCK_MODELS=false
# The API normally only writes durable outbox rows. Enable this only for local
# development when a separate `memoryos.worker` process is not running.
MEMORYOS_PROCESS_OUTBOX_INLINE=false

# Optional OpenAI-compatible extraction endpoint.
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT=15

# Maximum provider-backed LLM requests shared by this deployment each day.
# Local Ollama calls are not counted. Defaults to 50 when omitted.
LLM_DAILY_REQUEST_LIMIT=50
